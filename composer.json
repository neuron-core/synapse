{
    "name": "neuron-core/synapse",
    "description": "AI Coding Assistant built entirely in PHP with Neuron AI framework",
    "type": "library",
    "keywords": [
        "ai",
        "anthropic",
        "claude",
        "coding",
        "assistant",
        "symfony",
        "cli"
    ],
    "homepage": "https://github.com/neuron-core/synapse",
    "license": "MIT",
    "authors": [
        {
            "name": "Valerio Barbera",
            "email": "valerio@inspector.dev"
        }
    ],
    "support": {
        "issues": "https://github.com/neuron-core/synapse/issues",
        "source": "https://github.com/neuron-core/synapse"
    },
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "neuron-core/neuron-ai": "^3.0",
        "symfony/console": "^8.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.0",
        "rector/rector": "^2.0",
        "tomasvotruba/type-coverage": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "NeuronCore\\Synapse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NeuronCore\\Synapse\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/synapse"
    ],
    "scripts": {
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=1G -v"
        ],
        "format": [
            "@refactor",
            "@style"
        ],
        "style": [
            "php-cs-fixer fix --allow-risky=yes"
        ],
        "refactor": [
            "vendor/bin/rector"
        ],
        "test": [
            "vendor/bin/phpunit --colors=always"
        ]
    }
}
